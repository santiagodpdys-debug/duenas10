# ===========================
# Meta Ads (Facebook) Configuration
# ===========================
# Obten estos valores en https://developers.facebook.com/apps
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Token de acceso con permisos ads_management
# Genera un token con acceso prolongado (60+ días) en https://developers.facebook.com/tools/accesstoken/
META_ACCESS_TOKEN=your_meta_access_token

# IDs de cuenta de anuncios en Meta
# Encuentra estos IDs en https://business.facebook.com > Configuración > ID de cuenta de anuncios
# Formato: act_XXXXXXXXXX (sin "act_")
META_AD_ACCOUNT_CP1=your_account_id_cp1
META_AD_ACCOUNT_CP20=your_account_id_cp20
META_AD_ACCOUNT_CP25=your_account_id_cp25
META_AD_ACCOUNT_CP2=your_account_id_cp2

# ===========================
# WhatsApp Cloud API Configuration
# ===========================
# Token de acceso de WhatsApp Business API
# Genera en https://business.facebook.com > Configuración > Tokens de Acceso
WHATSAPP_TOKEN=your_whatsapp_token

# ID del número de teléfono de WhatsApp (Business Account)
# Encuentra en https://business.facebook.com > Configuración > Números de Teléfono
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Token de verificación (crear uno aleatorio para seguridad)
# Usa este valor cuando configures el webhook en Meta
WHATSAPP_VERIFY_TOKEN=your_random_verify_token_change_me

# ===========================
# Security Configuration
# ===========================
# Números de teléfono permitidos (formato: +código-país-número, separados por comas)
# Solo estos números pueden usar el bot
ALLOWED_PHONE_NUMBERS=+573228241532

# ===========================
# Flask Configuration
# ===========================
FLASK_ENV=production
FLASK_DEBUG=False
PORT=5000

# ===========================
# Logging Configuration
# ===========================
LOG_LEVEL=INFO
